---
import { useTranslations, languages, getLocalizedPath, defaultLang } from '../lib/i18n';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang === 'en' ? 'en' : 'fr');

const isHome = lang === defaultLang ? Astro.url.pathname === '/' : Astro.url.pathname === `/${lang}/`;
const isCatalogue = Astro.url.pathname.includes('/catalogue');
const isAbout = Astro.url.pathname.includes('/a-propos') || Astro.url.pathname.includes('/about');
const isContact = Astro.url.pathname.includes('/contact');
const isMember = Astro.url.pathname.includes('/membre') || Astro.url.pathname.includes('/member');
const isRegisterTab = isMember && Astro.url.search.includes('tab=register');
---

<header class="fixed top-0 left-0 right-0 z-50 bg-surface/95 backdrop-blur-sm border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={lang === defaultLang ? getLocalizedPath('', lang) : `/${lang}/`} class="flex items-center">
        <img src={`${import.meta.env.BASE_URL}/logo.jpg`} alt="Level Up - École Cyber Virtuelle" class="h-12 w-auto" />
      </a>

      <nav class="hidden md:flex items-center gap-4">
        <a href={lang === defaultLang ? getLocalizedPath('', lang) : `/${lang}/`}
           class:list={["nav-link", isHome && "active"]}
           class="text-sm font-medium transition-colors">
          {t.nav.home}
        </a>
        <a href={getLocalizedPath('catalogue', lang)}
           class:list={["nav-link", isCatalogue && "active"]}
           class="text-sm font-medium transition-colors">
          {t.nav.catalogue}
        </a>
        <a href={getLocalizedPath('membre', lang)}
           class:list={["btn-synthwave-nav", isRegisterTab ? "active-reg" : ""]}
           style={isRegisterTab ? "background: linear-gradient(180deg, #1a1a2e, #0f0f1a); color: #f72585; border-color: #f72585;" : ""}
           class="text-sm font-medium">
          {t.nav.login}
        </a>
        <a href={getLocalizedPath('membre', lang) + '?tab=register'}
           class:list={["btn-synthwave-nav", isRegisterTab ? "active-reg" : ""]}
           style={isRegisterTab ? "background: linear-gradient(180deg, #f72585, #7209b7); color: #fff; border-color: #f72585; box-shadow: 0 0 25px rgba(247, 37, 133, 0.6), 0 0 50px rgba(247, 37, 133, 0.3), 0 4px 0 #7209b7;" : "background: linear-gradient(180deg, #1a1a2e, #0f0f1a); color: #f72585; border-color: #f72585;"}
           class="text-sm font-medium">
          S'inscrire
        </a>
      </nav>

      <div class="flex items-center gap-4">
        <div class="relative group">
          <button class="flex items-center gap-1 text-sm font-medium text-text-muted hover:text-text transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
            {languages[lang as keyof typeof languages] || 'FR'}
          </button>
          <div class="absolute right-0 mt-2 w-32 bg-surface border border-border rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            {Object.entries(languages).map(([code, name]) => (
              <a
                href={lang === defaultLang ? `/${code}${Astro.url.pathname}` : `/${code}${Astro.url.pathname.replace(`/${lang}`, '')}`}
                class:list={["block px-4 py-2 text-sm hover:bg-surface-light transition-colors", lang === code && "text-primary"]}
              >
                {name}
              </a>
            ))}
          </div>
        </div>


      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-text-muted hover:text-text" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile/Tablet Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-surface border-t border-border">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-3">
      <a href={lang === defaultLang ? getLocalizedPath('', lang) : `/${lang}/`}
         class="block py-2 px-3 rounded-lg text-text hover:bg-surface-light transition-colors">
        {t.nav.home}
      </a>
      <a href={getLocalizedPath('catalogue', lang)}
         class="block py-2 px-3 rounded-lg text-text hover:bg-surface-light transition-colors">
        {t.nav.catalogue}
      </a>
      <div class="flex gap-3 pt-3 border-t border-border">
        <a href={getLocalizedPath('membre', lang)}
           class="flex-1 text-center btn-synthwave-nav text-sm font-medium">
          {t.nav.login}
        </a>
        <a href={getLocalizedPath('membre', lang) + '?tab=register'}
           class="flex-1 text-center btn-synthwave-nav text-sm font-medium"
           style="background: linear-gradient(180deg, #f72585, #7209b7); color: #fff; border-color: #f72585;">
          S'inscrire
        </a>
      </div>
    </div>
  </div>
</header>

<div class="h-16"></div>

<script>
const mobileMenuBtn = document.getElementById('mobile-menu-btn');
const mobileMenu = document.getElementById('mobile-menu');
mobileMenuBtn?.addEventListener('click', () => {
  mobileMenu?.classList.toggle('hidden');
});
// Close menu when clicking a link
mobileMenu?.querySelectorAll('a').forEach(link => {
  link.addEventListener('click', () => {
    mobileMenu?.classList.add('hidden');
  });
});
</script>
