---
import { useTranslations, getLocalizedPath, defaultLang } from '../lib/i18n';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang === 'en' ? 'en' : 'fr');
const year = new Date().getFullYear();
---

<footer class="bg-surface border-t border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <div class="mb-4">
          <img src="/file_000000009a2c71f48eac89c73d4c2381.png" alt="Level Up - Ecole Cyber Virtuelle" class="h-16 w-auto" />
        </div>
        <p class="text-text-muted text-sm max-w-md">
          {t.site.slogan}
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-text mb-4">Navigation</h4>
        <ul class="space-y-2">
          <li>
            <a href={getLocalizedPath('catalogue', lang)} class="text-text-muted hover:text-primary text-sm transition-colors">
              {t.nav.catalogue}
            </a>
          </li>
          <li>
            <a href={getLocalizedPath('a-propos', lang)} class="text-text-muted hover:text-primary text-sm transition-colors">
              {t.nav.about}
            </a>
          </li>
          <li>
            <a href={getLocalizedPath('contact', lang)} class="text-text-muted hover:text-primary text-sm transition-colors">
              {t.nav.contact}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-text mb-4">{t.legal.mentions}</h4>
        <ul class="space-y-2">
          <li>
            <a href={getLocalizedPath('mentions-legales', lang)} class="text-text-muted hover:text-primary text-sm transition-colors">
              {t.legal.mentions}
            </a>
          </li>
          <li>
            <a href={getLocalizedPath('cgv', lang)} class="text-text-muted hover:text-primary text-sm transition-colors">
              {t.legal.cgv}
            </a>
          </li>
          <li>
            <a href={getLocalizedPath('confidentialite', lang)} class="text-text-muted hover:text-primary text-sm transition-colors">
              {t.legal.privacy}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-border mt-8 pt-8 text-center">
      <p class="text-text-muted text-sm">
        &copy; {year} Level Up. {t.footer.copyright}.
      </p>
    </div>
  </div>
</footer>
