---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, defaultLang } from '../../lib/i18n';
const t = useTranslations('fr');

const lang = Astro.url.pathname.split('/')[1] || defaultLang;
---
<Layout title={t.admin.dashboard} lang={lang}>
  <section class="py-12" id="admin-content" style="display: none;">
    <div class="max-w-6xl mx-auto px-4 sm-px-6 lg-px-8">
      <div class="flex items-center justify-between mb-8">
        <h1 class="font-display text-3xl font-bold">{t.admin.title}</h1>
        <button id="logout-btn" class="px-4 py-2 bg-surface border border-border text-text-muted rounded-lg hover:text-text transition-colors">
          Déconnexion
        </button>
      </div>

      <!-- Tabs -->
      <div class="flex gap-2 mb-8 border-b border-border">
        <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-primary text-text" data-tab="create">Créer un cours</button>
        <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-tab="manage">Gérer le catalogue</button>
      </div>

      <!-- Create tab -->
      <div class="tab-content" id="tab-create">
        <div class="bg-surface rounded-xl p-8 space-y-6 mb-12 border border-border">
          <h2 class="text-xl font-semibold">Nouveau cours</h2>
          <form id="create-course-form" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-text">Titre (FR)</label>
                <input type="text" name="title" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="Ex: Sécurité des réseaux" />
              </div>
              <div>
                <label class="block text-sm font-medium text-text">Title (EN)</label>
                <input type="text" name="titleEn" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="Ex: Network Security" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Description courte (FR)</label>
              <textarea name="description" required rows="2" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="Description concise du cours"></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Description longue (FR)</label>
              <textarea name="longDescription" required rows="4" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="Description détaillée du cours"></textarea>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-text">Niveau</label>
                <select name="level" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5">
                  <option value="1">Niveau 1 — Débutant</option>
                  <option value="2">Niveau 2 — Intermédiaire</option>
                  <option value="3">Niveau 3 — Avancé</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-text">Prix (€)</label>
                <input type="number" name="price" step="0.01" min="0" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="49" />
              </div>
              <div>
                <label class="block text-sm font-medium text-text">Catégorie</label>
                <select name="category" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5">
                  <option value="cybersecurite">Cybersécurité</option>
                  <option value="reseaux">Réseaux</option>
                  <option value="cloud">Cloud</option>
                  <option value="conformite">Conformité</option>
                  <option value="forensique">Forensique</option>
                  <option value="devops">DevOps</option>
                  <option value="autre">Autre</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Image URL</label>
              <input type="text" name="imageUrl" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="https://images.pexels.com/... ou laisser vide pour défaut" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Tags (séparés par des virgules)</label>
              <input type="text" name="tags" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="securite, reseaux, firewall" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Compétences visées (séparées par des virgules)</label>
              <input type="text" name="competences" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="Configurer un firewall, Analyser des logs" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Public cible</label>
              <input type="text" name="public_cible" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="Administrateurs systèmes, Débutants en cybersécurité" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Prérequis</label>
              <textarea name="prerequis" rows="2" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="Connaissances de base en réseaux"></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Durée totale (heures)</label>
              <input type="number" name="duree_heures" min="1" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" placeholder="20" />
            </div>

            <!-- Modules -->
            <div class="border-t border-border pt-4">
              <div class="flex items-center justify-between mb-2">
                <label class="block text-sm font-medium text-text">Modules</label>
                <button type="button" id="add-module-btn" class="text-sm text-primary hover:text-primary/80 font-medium">+ Ajouter un module</button>
              </div>
              <div id="modules-container" class="space-y-3"></div>
            </div>

            <button type="submit" id="create-btn" class="w-full py-3 px-4 bg-gradient-to-r from-primary to-primary/80 text-background font-semibold rounded-lg hover:from-primary/90 hover:to-primary/70 transition-all shadow-lg">
              Créer le cours
            </button>
          </form>
        </div>
      </div>

      <!-- Manage tab -->
      <div class="tab-content" id="tab-manage" style="display: none;">
        <div class="bg-surface rounded-xl p-8 border border-border">
          <h2 class="text-xl font-semibold mb-4">Cours existants</h2>
          <div id="course-list" class="space-y-3">
            <p class="text-text-muted">Chargement...</p>
          </div>
        </div>
      </div>

      <!-- Edit modal -->
      <div id="edit-modal" class="fixed inset-0 bg-black/60 flex items-center justify-center z-50" style="display: none;">
        <div class="bg-surface border border-border rounded-xl p-8 max-w-3xl w-full mx-4 max-h-[90vh] overflow-y-auto">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-semibold">Modifier le cours</h2>
            <button id="close-edit-modal" class="text-text-muted hover:text-text text-2xl">&times;</button>
          </div>
          <form id="edit-course-form" class="space-y-4">
            <input type="hidden" name="slug" id="edit-slug" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-text">Titre (FR)</label>
                <input type="text" name="title" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
              </div>
              <div>
                <label class="block text-sm font-medium text-text">Title (EN)</label>
                <input type="text" name="titleEn" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Description courte</label>
              <textarea name="description" required rows="2" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Description longue</label>
              <textarea name="longDescription" required rows="4" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-sm font-medium text-text">Niveau</label>
                <select name="level" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5">
                  <option value="1">Niveau 1</option>
                  <option value="2">Niveau 2</option>
                  <option value="3">Niveau 3</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-text">Prix (€)</label>
                <input type="number" name="price" step="0.01" min="0" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
              </div>
              <div>
                <label class="block text-sm font-medium text-text">Catégorie</label>
                <select name="category" required class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5">
                  <option value="cybersecurite">Cybersécurité</option>
                  <option value="reseaux">Réseaux</option>
                  <option value="cloud">Cloud</option>
                  <option value="conformite">Conformité</option>
                  <option value="forensique">Forensique</option>
                  <option value="devops">DevOps</option>
                  <option value="autre">Autre</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Image URL</label>
              <input type="text" name="imageUrl" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Tags (virgules)</label>
              <input type="text" name="tags" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Compétences (virgules)</label>
              <input type="text" name="competences" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Public cible</label>
              <input type="text" name="public_cible" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Prérequis</label>
              <textarea name="prerequis" rows="2" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
            </div>
            <div>
              <label class="block text-sm font-medium text-text">Durée (heures)</label>
              <input type="number" name="duree_heures" min="1" class="mt-1 block w-full rounded-md bg-background border border-border text-text p-2.5" />
            </div>
            <div class="flex gap-3 pt-4">
              <button type="submit" class="flex-1 py-3 px-4 bg-gradient-to-r from-primary to-primary/80 text-background font-semibold rounded-lg hover:from-primary/90 hover:to-primary/70 transition-all">
                Sauvegarder
              </button>
              <button type="button" id="cancel-edit" class="py-3 px-4 bg-surface border border-border text-text-muted rounded-lg hover:text-text">
                Annuler
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // --- Client-side auth gate ---
  (async () => {
    const content = document.getElementById('admin-content');
    if (!content) return;

    function getCookie(name) {
      const match = document.cookie.match(new RegExp('(?:^|;)\\s*' + name + '=([^;]*)'));
      return match ? decodeURIComponent(match[1]) : null;
    }

    const cookieToken = getCookie('sb-auth-token');
    const lsToken = localStorage.getItem('sb-auth-token');
    const token = cookieToken || lsToken;

    if (!token) {
      window.location.href = '/Level-Up-Formation/admin/login';
      return;
    }

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    if (!supabaseUrl || !supabaseAnonKey) {
      content.innerHTML = '<div class="max-w-4xl mx-auto px-4"><p class="text-red-600">Configuration Supabase manquante.</p></div>';
      content.style.display = 'block';
      return;
    }

    try {
      const userStr = localStorage.getItem('sb-auth-user');
      if (!userStr) {
        localStorage.removeItem('sb-auth-token');
        document.cookie = 'sb-auth-token=; path=/; max-age=0';
        window.location.href = '/Level-Up-Formation/admin/login';
        return;
      }
      const userEmail = JSON.parse(userStr).email;

      const profileRes = await fetch(`${supabaseUrl}/rest/v1/profiles?select=role&email=eq.${encodeURIComponent(userEmail)}`, {
        headers: {
          'apikey': supabaseAnonKey,
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      if (!profileRes.ok) {
        localStorage.removeItem('sb-auth-token');
        localStorage.removeItem('sb-auth-user');
        document.cookie = 'sb-auth-token=; path=/; max-age=0';
        window.location.href = '/Level-Up-Formation/admin/login';
        return;
      }

      const profileData = await profileRes.json();

      if (profileData.length === 0 || profileData[0].role !== 'admin') {
        localStorage.removeItem('sb-auth-token');
        localStorage.removeItem('sb-auth-user');
        document.cookie = 'sb-auth-token=; path=/; max-age=0';
        window.location.href = '/Level-Up-Formation/admin/login';
        return;
      }

      content.style.display = 'block';
      loadCourses(token, supabaseUrl, supabaseAnonKey);
    } catch (err) {
      console.error('[admin] auth error:', err);
      localStorage.removeItem('sb-auth-token');
      localStorage.removeItem('sb-auth-user');
      document.cookie = 'sb-auth-token=; path=/; max-age=0';
      window.location.href = '/Level-Up-Formation/admin/login';
    }
  })();

  // --- Tab switching ---
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const tab = e.currentTarget.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('border-primary', 'text-text');
        b.classList.add('border-transparent', 'text-text-muted');
      });
      e.currentTarget.classList.remove('border-transparent', 'text-text-muted');
      e.currentTarget.classList.add('border-primary', 'text-text');
      document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
      document.getElementById(`tab-${tab}`).style.display = 'block';
    });
  });

  // --- Load and display courses ---
  async function loadCourses(token, supabaseUrl, supabaseAnonKey) {
    const listEl = document.getElementById('course-list');
    if (!listEl) return;

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/courses?select=*&order=created_at.desc`, {
        headers: {
          'apikey': supabaseAnonKey,
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      if (!res.ok) {
        listEl.innerHTML = '<p class="text-text-muted">Aucun cours en base. Créez-en un depuis l\'onglet "Créer un cours".</p>';
        return;
      }

      const courses = await res.json();

      if (courses.length === 0) {
        listEl.innerHTML = '<p class="text-text-muted">Aucun cours en base.</p>';
        return;
      }

      listEl.innerHTML = '';
      courses.forEach(course => {
        const div = document.createElement('div');
        div.className = 'flex items-center justify-between bg-background border border-border rounded-lg p-4';
        div.innerHTML = `
          <div class="flex-1">
            <h3 class="font-semibold text-lg">${course.title}</h3>
            <p class="text-text-muted text-sm">${course.description || ''}</p>
            <div class="flex gap-2 mt-1 flex-wrap">
              <span class="text-xs bg-blue-100 text-blue-800 px-2 py-0.5 rounded">Niveau ${course.level}</span>
              <span class="text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded">${course.price}€</span>
              <span class="text-xs bg-purple-100 text-purple-800 px-2 py-0.5 rounded">${course.category || ''}</span>
            </div>
          </div>
          <div class="ml-4 flex gap-2">
            <button class="edit-btn px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm" data-slug="${course.slug}">Modifier</button>
            <button class="delete-btn px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors text-sm" data-slug="${course.slug}">Supprimer</button>
          </div>
        `;
        listEl.appendChild(div);
      });

      document.querySelectorAll('.edit-btn').forEach(btn => btn.addEventListener('click', handleEdit));
      document.querySelectorAll('.delete-btn').forEach(btn => btn.addEventListener('click', handleDelete));
    } catch (err) {
      listEl.innerHTML = '<p class="text-red-600">Erreur lors du chargement des cours.</p>';
    }
  }

  // --- Module management ---
  let moduleCount = 0;

  function addModule() {
    const container = document.getElementById('modules-container');
    if (!container) return;
    const id = moduleCount++;
    const div = document.createElement('div');
    div.className = 'module-item bg-background border border-border rounded-lg p-4 space-y-2';
    div.dataset.moduleId = id;
    div.innerHTML = `
      <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-text-muted">Module ${id + 1}</span>
        <button type="button" class="remove-module text-red-500 hover:text-red-700 text-sm">&times; Supprimer</button>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <input type="text" name="mod_title" placeholder="Titre (FR)" class="block w-full rounded-md bg-surface border border-border text-text p-2" />
        <input type="text" name="mod_titleEn" placeholder="Title (EN)" class="block w-full rounded-md bg-surface border border-border text-text p-2" />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
        <input type="text" name="mod_description" placeholder="Description" class="block w-full rounded-md bg-surface border border-border text-text p-2" />
        <input type="number" name="mod_duration" placeholder="Durée (ex: 1h30)" class="block w-full rounded-md bg-surface border border-border text-text p-2" />
        <select name="mod_order" class="block w-full rounded-md bg-surface border border-border text-text p-2">
          <option value="0">Ordre 0</option>
          <option value="1">Ordre 1</option>
          <option value="2">Ordre 2</option>
          <option value="3">Ordre 3</option>
          <option value="4">Ordre 4</option>
          <option value="5">Ordre 5</option>
          <option value="6">Ordre 6</option>
          <option value="7">Ordre 7</option>
          <option value="8">Ordre 8</option>
          <option value="9">Ordre 9</option>
        </select>
      </div>
      <label class="flex items-center gap-2 text-sm text-text-muted">
        <input type="checkbox" name="mod_isFree" class="rounded border-border" /> Module gratuit (accès free)
      </label>
    `;
    container.appendChild(div);
    div.querySelector('.remove-module').addEventListener('click', () => div.remove());
  }

  document.getElementById('add-module-btn')?.addEventListener('click', addModule);

  // --- Handle course creation ---
  document.getElementById('create-course-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('create-btn');
    btn.disabled = true;
    btn.textContent = 'Création...';

    const token = localStorage.getItem('sb-auth-token') || document.cookie.split('sb-auth-token=')[1]?.split(';')[0];
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    if (!token || !supabaseUrl || !supabaseAnonKey) {
      alert('Erreur de configuration.');
      btn.disabled = false;
      btn.textContent = 'Créer le cours';
      return;
    }

    const formData = new FormData(e.target);
    const title = formData.get('title');
    const slug = title.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');

    // Build modules array
    const moduleItems = document.querySelectorAll('.module-item');
    const modules = [];
    moduleItems.forEach((item, idx) => {
      const modTitle = item.querySelector('[name="mod_title"]')?.value;
      if (!modTitle) return;
      modules.push({
        id: `${slug}-mod-${idx}`,
        title: modTitle,
        titleEn: item.querySelector('[name="mod_titleEn"]')?.value || modTitle,
        description: item.querySelector('[name="mod_description"]')?.value || '',
        descriptionEn: item.querySelector('[name="mod_descriptionEn"]')?.value || '',
        isFree: item.querySelector('[name="mod_isFree"]')?.checked || false,
        order: parseInt(item.querySelector('[name="mod_order"]')?.value) || idx,
        duration: item.querySelector('[name="mod_duration"]')?.value || '1h'
      });
    });

    const courseData = {
      id: crypto.randomUUID(),
      slug: slug,
      title: title,
      titleEn: formData.get('titleEn'),
      description: formData.get('description'),
      descriptionEn: formData.get('descriptionEn') || formData.get('titleEn'),
      longDescription: formData.get('longDescription'),
      longDescriptionEn: formData.get('longDescriptionEn') || formData.get('longDescription'),
      level: parseInt(formData.get('level')),
      price: parseFloat(formData.get('price')),
      modules: modules,
      image: formData.get('imageUrl') || 'https://images.pexels.com/photos/60504/security-hacker-black-background-60504.jpeg?w=800',
      tags: formData.get('tags')?.split(',').map(t => t.trim()).filter(Boolean),
      category: formData.get('category'),
      competences: formData.get('competences')?.split(',').map(c => c.trim()).filter(Boolean),
      public_cible: formData.get('public_cible'),
      prerequis: formData.get('prerequis'),
      duree_heures: parseInt(formData.get('duree_heures')) || modules.reduce((sum, m) => sum + (parseInt(m.duration) || 1), 0),
      created_at: new Date().toISOString()
    };

    try {
      // Save to Supabase
      const res = await fetch(`${supabaseUrl}/rest/v1/courses`, {
        method: 'POST',
        headers: {
          'apikey': supabaseAnonKey,
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=representation'
        },
        body: JSON.stringify(courseData)
      });

      if (!res.ok) {
        const err = await res.text();
        throw new Error(`Supabase: ${res.status} — ${err}`);
      }

      alert(`Cours "${courseData.title}" créé avec succès dans Supabase !`);
      loadCourses(token, supabaseUrl, supabaseAnonKey);
      e.target.reset();
      document.getElementById('modules-container').innerHTML = '';
      moduleCount = 0;

    } catch (err) {
      console.error('[admin] create error:', err);
      alert(`Erreur: ${err.message}`);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Créer le cours';
    }
  });

  // --- Handle edit ---
  async function handleEdit(e) {
    const btn = e.currentTarget;
    const slug = btn.dataset.slug;
    if (!slug) return;

    const token = localStorage.getItem('sb-auth-token');
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/courses?slug=eq.${encodeURIComponent(slug)}&select=*`, {
        headers: {
          'apikey': supabaseAnonKey,
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      if (!res.ok) throw new Error('Cours non trouvé en base');
      const data = await res.json();
      const course = data[0];

      document.getElementById('edit-slug').value = course.slug;
      const form = document.getElementById('edit-course-form');
      form.querySelector('[name="title"]').value = course.title || '';
      form.querySelector('[name="titleEn"]').value = course.titleEn || '';
      form.querySelector('[name="description"]').value = course.description || '';
      form.querySelector('[name="longDescription"]').value = course.longDescription || '';
      form.querySelector('[name="level"]').value = course.level || 1;
      form.querySelector('[name="price"]').value = course.price || 0;
      form.querySelector('[name="category"]').value = course.category || 'cybersecurite';
      form.querySelector('[name="imageUrl"]').value = course.image || '';
      form.querySelector('[name="tags"]').value = (course.tags || []).join(', ');
      form.querySelector('[name="competences"]').value = (course.competences || []).join(', ');
      form.querySelector('[name="public_cible"]').value = course.public_cible || '';
      form.querySelector('[name="prerequis"]').value = course.prerequis || '';
      form.querySelector('[name="duree_heures"]').value = course.duree_heures || '';

      document.getElementById('edit-modal').style.display = 'flex';
    } catch (err) {
      alert(`Erreur: ${err.message}`);
    }
  }

  // --- Handle edit save ---
  document.getElementById('edit-course-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const slug = document.getElementById('edit-slug').value;
    const formData = new FormData(e.target);

    const token = localStorage.getItem('sb-auth-token');
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    const updateData = {
      title: formData.get('title'),
      titleEn: formData.get('titleEn'),
      description: formData.get('description'),
      longDescription: formData.get('longDescription'),
      level: parseInt(formData.get('level')),
      price: parseFloat(formData.get('price')),
      category: formData.get('category'),
      image: formData.get('imageUrl'),
      tags: formData.get('tags')?.split(',').map(t => t.trim()).filter(Boolean),
      competences: formData.get('competences')?.split(',').map(c => c.trim()).filter(Boolean),
      public_cible: formData.get('public_cible'),
      prerequis: formData.get('prerequis'),
      duree_heures: parseInt(formData.get('duree_heures'))
    };

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/courses?slug=eq.${encodeURIComponent(slug)}`, {
        method: 'PATCH',
        headers: {
          'apikey': supabaseAnonKey,
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=representation'
        },
        body: JSON.stringify(updateData)
      });

      if (!res.ok) {
        const err = await res.text();
        throw new Error(`Supabase: ${res.status} — ${err}`);
      }

      alert('Cours mis à jour avec succès !');
      document.getElementById('edit-modal').style.display = 'none';
      loadCourses(token, supabaseUrl, supabaseAnonKey);

    } catch (err) {
      console.error('[admin] edit error:', err);
      alert(`Erreur: ${err.message}`);
    }
  });

  // --- Handle course deletion ---
  async function handleDelete(e) {
    const btn = e.currentTarget;
    const slug = btn.dataset.slug;
    if (!slug) return;

    if (!confirm(`Êtes-vous sûr de vouloir supprimer "${slug}" ?\n\nCette action est irréversible.`)) return;
    btn.disabled = true;
    btn.textContent = 'Suppression...';

    const token = localStorage.getItem('sb-auth-token');
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    try {
      // Find course by slug
      const courseRes = await fetch(`${supabaseUrl}/rest/v1/courses?slug=eq.${encodeURIComponent(slug)}&select=id`, {
        headers: {
          'apikey': supabaseAnonKey,
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      if (courseRes.ok) {
        const courseData = await courseRes.json();
        if (courseData.length > 0) {
          const deleteRes = await fetch(`${supabaseUrl}/rest/v1/courses?id=eq.${courseData[0].id}`, {
            method: 'DELETE',
            headers: {
              'apikey': supabaseAnonKey,
              'Authorization': `Bearer ${token}`,
              'Content-Type': 'application/json',
              'Prefer': 'return=representation'
            }
          });

          if (deleteRes.ok) {
            const courseEl = btn.closest('.flex');
            if (courseEl) {
              courseEl.style.transition = 'opacity 0.3s';
              courseEl.style.opacity = '0';
              setTimeout(() => courseEl.remove(), 300);
            }
            alert(`Cours "${slug}" supprimé avec succès !`);
          } else {
            throw new Error(`Supabase: ${deleteRes.status}`);
          }
        }
      }
    } catch (err) {
      console.error('[admin] delete error:', err);
      alert(`Erreur: ${err.message}`);
      btn.disabled = false;
      btn.textContent = 'Supprimer';
    }
  }

  // --- Logout ---
  document.getElementById('logout-btn')?.addEventListener('click', () => {
    localStorage.removeItem('sb-auth-token');
    localStorage.removeItem('sb-auth-user');
    document.cookie = 'sb-auth-token=; path=/; max-age=0';
    window.location.href = '/Level-Up-Formation/admin/login';
  });

  // --- Close edit modal ---
  document.getElementById('close-edit-modal')?.addEventListener('click', () => {
    document.getElementById('edit-modal').style.display = 'none';
  });
  document.getElementById('cancel-edit')?.addEventListener('click', () => {
    document.getElementById('edit-modal').style.display = 'none';
  });
  document.getElementById('edit-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) e.currentTarget.style.display = 'none';
  });
</script>
