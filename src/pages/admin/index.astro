---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, defaultLang } from '../../lib/i18n';
const t = useTranslations('fr');

const lang = Astro.url.pathname.split('/')[1] || defaultLang;
---
<Layout title={t.admin.dashboard} lang={lang}>
  <!-- Content hidden by default — shown only after auth verification -->
  <section class="py-12" id="admin-content" style="display: none;">
    <div class="max-w-4xl mx-auto px-4 sm-px-6 lg-px-8">
      <h1 class="font-display text-3xl font-bold mb-8">{t.admin.title}</h1>

      <div class="bg-surface rounded-xl p-8 space-y-8 mb-12">
        <div>
          <h2 class="text-xl font-semibold mb-4">{t.admin.add_course}</h2>
          <form method="POST" action="/api/admin/courses">
            <div class="space-y-4">
              <div>
                <label class="block text-text-sm font-medium">{t.admin.title}</label>
                <input type="text" name="title" required class="mt-1 block w-full rounded-md bg-surface border border-border text-text p-2.5" />
              </div>
              <div>
                <label class="block text-text-sm font-medium">{t.admin.level}</label>
                <select name="level" required class="mt-1 block w-full rounded-md bg-surface border border-border text-text p-2.5">
                  <option value="1">{t.admin.level_1}</option>
                  <option value="2">{t.admin.level_2}</option>
                  <option value="3">{t.admin.level_3}</option>
                </select>
              </div>
              <div>
                <label class="block text-text-sm font-medium">{t.admin.price}</label>
                <input type="number" name="price" step="0.01" required class="mt-1 block w-full rounded-md bg-surface border border-border text-text p-2.5" />
              </div>
              <div>
                <label class="block text-text-sm font-medium">{t.admin.document}</label>
                <input type="file" name="document" accept=".pdf,.docx" required class="mt-1 block w-full rounded-md bg-surface border border-border text-text p-2.5" />
              </div>
              <div>
                <label class="block text-text-sm font-medium">{t.admin.image}</label>
                <input type="file" name="image" accept=".jpg,.png" class="mt-1 block w-full rounded-md bg-surface border border-border text-text p-2.5" />
              </div>
            </div>
          </form>
        </div>

        <div>
          <h2 class="text-xl font-semibold mb-4">{t.admin.existing_courses}</h2>
          <div id="course-list" class="space-y-3">
            <!-- Courses will be loaded dynamically -->
            <p class="text-text-muted">Chargement...</p>
          </div>
        </div>
      </div>

      <div class="space-y-8">
        <h2 class="text-xl font-semibold">{t.admin.manage_catalog}</h2>
        <p class="text-text-muted">{t.admin.manage_desc}</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // --- Client-side auth gate (runs before any content is visible) ---
  (async () => {
    const content = document.getElementById('admin-content');
    if (!content) return;

    // Check token in cookie first (for direct navigation), then localStorage
    function getCookie(name) {
      const match = document.cookie.match(new RegExp('(?:^|;)\\s*' + name + '=([^;]*)'));
      return match ? decodeURIComponent(match[1]) : null;
    }

    const cookieToken = getCookie('sb-auth-token');
    const lsToken = localStorage.getItem('sb-auth-token');
    const token = cookieToken || lsToken;

    if (!token) {
      window.location.href = '/Level-Up-Formation/admin/login';
      return;
    }

    // Verify token is valid and check admin role
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    try {
      const profileRes = await fetch(`${supabaseUrl}/rest/v1/profiles?select=role&email=eq.${encodeURIComponent('jo@levelup-formation.fr')}`, {
        headers: {
          'apikey': supabaseAnonKey,
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      if (!profileRes.ok) {
        localStorage.removeItem('sb-auth-token');
        localStorage.removeItem('sb-auth-user');
        document.cookie = 'sb-auth-token=; path=/; max-age=0';
        window.location.href = '/Level-Up-Formation/admin/login';
        return;
      }

      const profileData = await profileRes.json();

      if (profileData.length === 0 || profileData[0].role !== 'admin') {
        localStorage.removeItem('sb-auth-token');
        localStorage.removeItem('sb-auth-user');
        document.cookie = 'sb-auth-token=; path=/; max-age=0';
        window.location.href = '/Level-Up-Formation/admin/login';
        return;
      }

      // Auth verified — show content
      content.style.display = 'block';

      // Load courses list
      loadCourses(token);
    } catch (err) {
      localStorage.removeItem('sb-auth-token');
      localStorage.removeItem('sb-auth-user');
      document.cookie = 'sb-auth-token=; path=/; max-age=0';
      window.location.href = '/Level-Up-Formation/admin/login';
      return;
    }
  })();

  // --- Load and display courses ---
  async function loadCourses(token) {
    const listEl = document.getElementById('course-list');
    if (!listEl) return;

    try {
      const res = await fetch('/api/admin/courses', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const courses = await res.json();

      listEl.innerHTML = '';
      courses.forEach(course => {
        const div = document.createElement('div');
        div.className = 'flex items-center justify-between bg-surface border border-border rounded-lg p-4';
        div.innerHTML = `
          <div class="flex-1">
            <h3 class="font-semibold text-lg">${course.title}</h3>
            <p class="text-text-muted text-sm">${course.description}</p>
            <div class="flex gap-2 mt-1">
              <span class="text-xs bg-blue-100 text-blue-800 px-2 py-0.5 rounded">Niveau ${course.level}</span>
              <span class="text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded">${course.price}€</span>
            </div>
          </div>
          <div class="ml-4">
            <button
              class="delete-btn px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors"
              data-slug="${course.slug}"
            >
              Supprimer
            </button>
          </div>
        `;
        listEl.appendChild(div);
      });

      // Attach delete handlers
      document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', handleDelete);
      });
    } catch (err) {
      listEl.innerHTML = '<p class="text-red-600">Erreur lors du chargement des cours.</p>';
    }
  }

  // --- Handle course deletion ---
  async function handleDelete(e) {
    const btn = e.currentTarget;
    const slug = btn.getAttribute('data-slug');
    console.log('[admin] handleDelete clicked, slug:', slug);
    if (!slug) return;

    // Confirm deletion
    if (!confirm(`Êtes-vous sûr de vouloir supprimer "${slug}" ?\n\nCette action est irréversible : le cours sera supprimé du catalogue, de la base de données et des fichiers locaux.`)) {
      return;
    }
    btn.disabled = true;
    btn.textContent = 'Suppression...';

    // Get token
    function getCookie(name) {
      const match = document.cookie.match(new RegExp('(?:^|;)\\s*' + name + '=([^;]*)'));
      return match ? decodeURIComponent(match[1]) : null;
    }
    const cookieToken = getCookie('sb-auth-token');
    const lsToken = localStorage.getItem('sb-auth-token');
    const token = cookieToken || lsToken;
    console.log('[admin] token:', token ? token.substring(0, 20) + '...' : 'NULL');

    try {
      const url = `/api/admin/courses/${slug}`;
      console.log('[admin] DELETE', url);

      const res = await fetch(url, {
        method: 'DELETE',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });

      console.log('[admin] response status:', res.status);
      const result = await res.json();
      console.log('[admin] response body:', JSON.stringify(result, null, 2));

      if (res.ok) {
        // Remove from DOM
        const courseEl = btn.closest('.flex');
        console.log('[admin] courseEl found:', !!courseEl);
        if (courseEl) {
          courseEl.style.transition = 'opacity 0.3s';
          courseEl.style.opacity = '0';
          setTimeout(() => {
            courseEl.remove();
            console.log('[admin] course element removed from DOM');
          }, 300);
        }
        if (result.deleted && result.deleted.catalog !== false) {
          alert(`Cours supprimé avec succès !\n\nFichiers supprimés: ${result.deleted.files.length}\nCatalogue: ${result.deleted.catalog ? 'Oui' : 'Non'}`);
        } else {
          alert(`Cours supprimé !\n\n${result.errors ? result.errors.join('\n') : 'Cours supprimé.'}`);
        }
      } else {
        alert(`Erreur (${res.status}): ${result.error || 'Erreur inconnue'}`);
        btn.disabled = false;
        btn.textContent = 'Supprimer';
      }
    } catch (err) {
      console.error('[admin] fetch error:', err);
      alert(`Erreur de connexion: ${err.message}`);
      btn.disabled = false;
      btn.textContent = 'Supprimer';
    }
  }
</script>
