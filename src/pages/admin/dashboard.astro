---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl } from '../../lib/i18n';

const lang = getLangFromUrl(Astro.url);
// Dashboard is fully dynamic — loaded from Supabase client-side.
// This empty array is only for static build compatibility.
const courses: any[] = [];
const t = {
  fr: {
    title: 'Administration - Catalogue',
    subtitle: 'Gestion complète des cours',
    addCourse: 'Ajouter un cours',
    tableHeaders: ['Image', 'Titre', 'Slug', 'Niveau', 'Prix', 'Modules', 'Actions'],
    levelLabels: { 1: 'LVL 1 - 49€', 2: 'LVL 2 - 89€', 3: 'LVL 3 - 149€' },
    edit: 'Modifier',
    delete: 'Supprimer',
    confirmDelete: 'Confirmer la suppression ?',
    noCourses: 'Aucun cours pour le moment',
    loading: 'Chargement...',
  },
  en: {
    title: 'Admin - Catalog',
    subtitle: 'Complete course management',
    addCourse: 'Add Course',
    tableHeaders: ['Image', 'Title', 'Slug', 'Level', 'Price', 'Modules', 'Actions'],
    levelLabels: { 1: 'LVL 1 - 49€', 2: 'LVL 2 - 89€', 3: 'LVL 3 - 149€' },
    edit: 'Edit',
    delete: 'Delete',
    confirmDelete: 'Confirm deletion?',
    noCourses: 'No courses yet',
    loading: 'Loading...',
  }
}[lang];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="Administration Level Up Formation" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@500;600;700&display=swap" rel="stylesheet">
    <title>Admin | Level Up</title>
    <style>
      :root {
        --bg: #0a0a0a;
        --bg-card: rgba(255, 255, 255, 0.03);
        --border: rgba(255, 255, 255, 0.08);
        --text: #e8e8e8;
        --text-muted: #888;
        --accent: #00ff88;
        --accent-dim: #00cc66;
        --danger: #ff4444;
        --warning: #ffaa00;
      }
      
      * { box-sizing: border-box; }
      body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
      
      .admin-layout { display: flex; flex-direction: column; min-height: 100vh; }
      main { flex: 1; padding: 40px 20px; max-width: 1400px; width: 100%; margin: 0 auto; }
      
      .admin-header { margin-bottom: 32px; }
      .admin-header h1 { font-family: 'Orbitron', sans-serif; font-size: 2rem; color: var(--accent); margin: 0 0 8px; }
      .admin-header p { color: var(--text-muted); margin: 0; }
      
      .toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; }
      .btn { 
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 24px; border-radius: 8px; font-weight: 600; font-size: 0.95rem;
        border: none; cursor: pointer; transition: all 0.2s; text-decoration: none;
      }
      .btn-primary { background: linear-gradient(135deg, var(--accent), var(--accent-dim)); color: #000; }
      .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0, 255, 136, 0.3); }
      .btn-danger { background: transparent; color: var(--danger); border: 1px solid var(--danger); }
      .btn-danger:hover { background: var(--danger); color: #000; }
      .btn-secondary { background: var(--bg-card); color: var(--text); border: 1px solid var(--border); }
      .btn-secondary:hover { border-color: var(--accent); }
      
      .table-container { 
        background: var(--bg-card); 
        border: 1px solid var(--border); 
        border-radius: 16px; 
        overflow: hidden;
        backdrop-filter: blur(10px);
      }
      table { width: 100%; border-collapse: collapse; }
      th, td { padding: 16px 20px; text-align: left; border-bottom: 1px solid var(--border); }
      th { background: rgba(255, 255, 255, 0.02); font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); }
      tr:last-child td { border-bottom: none; }
      tr:hover td { background: rgba(255, 255, 255, 0.01); }
      
      .course-thumb { width: 60px; height: 34px; border-radius: 6px; object-fit: cover; border: 1px solid var(--border); }
      .course-title { font-weight: 600; }
      .course-slug { font-family: monospace; font-size: 0.85rem; color: var(--text-muted); }
      .level-badge { 
        display: inline-block; padding: 4px 12px; border-radius: 20px; 
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
      }
      .level-1 { background: rgba(0, 255, 136, 0.15); color: var(--accent); border: 1px solid rgba(0, 255, 136, 0.3); }
      .level-2 { background: rgba(0, 180, 255, 0.15); color: #00b4ff; border: 1px solid rgba(0, 180, 255, 0.3); }
      .level-3 { background: rgba(255, 100, 200, 0.15); color: #ff64c8; border: 1px solid rgba(255, 100, 200, 0.3); }
      .price { font-weight: 700; font-family: 'Orbitron', sans-serif; }
      .actions { display: flex; gap: 8px; }
      .action-btn { 
        padding: 8px 16px; border-radius: 6px; font-size: 0.8rem; font-weight: 600;
        border: none; cursor: pointer; transition: all 0.2s; text-decoration: none;
      }
      .action-btn.edit { background: var(--bg-card); color: var(--text); border: 1px solid var(--border); }
      .action-btn.edit:hover { border-color: var(--accent); color: var(--accent); }
      .action-btn.delete { background: transparent; color: var(--danger); border: 1px solid var(--danger); }
      .action-btn.delete:hover { background: var(--danger); color: #000; }
      
      .empty-state { text-align: center; padding: 60px 20px; color: var(--text-muted); }
      .empty-state h3 { font-family: 'Orbitron', sans-serif; color: var(--text); margin-bottom: 16px; }
      
      .loading-state { text-align: center; padding: 60px 20px; color: var(--text-muted); }
      .loading-state h3 { font-family: 'Orbitron', sans-serif; color: var(--text); margin-bottom: 16px; }
      
      @media (max-width: 768px) {
        th:nth-child(1), td:nth-child(1),
        th:nth-child(3), td:nth-child(3) { display: none; }
        .toolbar { flex-direction: column; align-items: stretch; }
      }
    </style>
  </head>
  <body class="admin-layout">
    <Header lang={lang} />
    <!-- Content hidden by default — shown only after auth verification -->
    <main id="admin-content" style="display: none;">
      <div class="admin-header">
        <h1>{t.title}</h1>
        <p>{t.subtitle}</p>
      </div>
      
      <div class="toolbar">
        <a href="/Level-Up-Formation/admin/creer" class="btn btn-primary">+ {t.addCourse}</a>
      </div>
      
      <div class="table-container">
        {courses.length > 0 ? (
          <table>
            <thead>
              <tr>
                {t.tableHeaders.map(h => <th>{h}</th>)}
              </tr>
            </thead>
            <tbody>
              {courses.map(course => (
                <tr>
                  <td>
                    <img src={course.image} alt="" class="course-thumb" loading="lazy" 
                         onerror="this.style.display='none'" />
                  </td>
                  <td class="course-title">{course.title}</td>
                  <td class="course-slug">{course.slug}</td>
                  <td>
                    <span class="level-badge level-{course.level}">
                      {t.levelLabels[course.level as 1|2|3]}
                    </span>
                  </td>
                  <td class="price">{course.price}€</td>
                  <td>{course.modules.length} modules</td>
                  <td>
                    <div class="actions">
                      <a href={`/Level-Up-Formation/admin/editer/${course.slug}`} class="action-btn edit">{t.edit}</a>
                      <button class="action-btn delete" 
                              data-slug={course.slug} 
                              data-title={course.title}
                              onclick="confirmDelete(this)">{t.delete}</button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <div class="empty-state">
            <h3>{t.noCourses}</h3>
            <p>Aucun cours configuré. Cliquez sur "Ajouter un cours" pour commencer.</p>
            <a href="/Level-Up-Formation/admin/creer" class="btn btn-primary" style="margin-top: 16px; display: inline-block;">+ {t.addCourse}</a>
          </div>
        )}
      </div>
    </main>
    <Footer lang={lang} />
    
    <script>
      // --- Config ---
      const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
      const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
      const GITHUB_REPO = 'geoffreylacroixformation-blip/Level-Up-Formation';
      const GITHUB_FILE = 'src/lib/courses.ts';

      // --- Helpers ---
      function getCookie(name) {
        const match = document.cookie.match(new RegExp('(?:^|;)\\s*' + name + '=([^;]*)'));
        return match ? decodeURIComponent(match[1]) : null;
      }

      function getToken() {
        return getCookie('sb-auth-token') || localStorage.getItem('sb-auth-token');
      }

      function getUserEmail() {
        const userStr = localStorage.getItem('sb-auth-user');
        return userStr ? JSON.parse(userStr).email : null;
      }

      function logout() {
        localStorage.removeItem('sb-auth-token');
        localStorage.removeItem('sb-auth-user');
        document.cookie = 'sb-auth-token=; path=/; max-age=0';
        window.location.href = '/Level-Up-Formation/admin/login';
      }

      // --- Level badge ---
      function levelBadge(level, t) {
        const labels = { 1: 'LVL 1 - 49€', 2: 'LVL 2 - 89€', 3: 'LVL 3 - 149€' };
        return `<span class="level-badge level-${level}">${labels[level] || level}</span>`;
      }

      // --- Render table ---
      function renderTable(courses, tbody) {
        tbody.innerHTML = '';
        if (courses.length === 0) {
          tbody.innerHTML = `<tr><td colspan="7" class="empty-state"><h3>Aucun cours en base</h3></td></tr>`;
          return;
        }
        courses.forEach(course => {
          const tr = document.createElement('tr');
          tr.dataset.slug = course.slug;
          tr.innerHTML = `
            <td><img src="${course.image}" alt="" class="course-thumb" loading="lazy" onerror="this.style.display='none'" /></td>
            <td class="course-title">${course.title}</td>
            <td class="course-slug">${course.slug}</td>
            <td>${levelBadge(course.level, {})}</td>
            <td class="price">${course.price}€</td>
            <td>${(course.modules || []).length} modules</td>
            <td>
              <div class="actions">
                <a href="/Level-Up-Formation/admin/editer/${course.slug}" class="action-btn edit">Modifier</a>
                <button class="action-btn delete" data-slug="${course.slug}" data-title="${course.title}" onclick="confirmDelete(this)">Supprimer</button>
              </div>
            </td>
          `;
          tbody.appendChild(tr);
        });
      }

      // --- Refresh from Supabase ---
      async function refreshCourses() {
        const token = getToken();
        if (!token || !SUPABASE_URL) return;

        const tbody = document.querySelector('#admin-content tbody');
        if (!tbody) return;

        tbody.innerHTML = '<tr><td colspan="7" class="loading-state"><h3>Chargement...</h3></td></tr>';

        try {
          const res = await fetch(
            `${SUPABASE_URL}/rest/v1/courses?select=*,modules(*),image,title,slug,level,price`,
            {
              headers: {
                'apikey': SUPABASE_KEY,
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json',
                'Prefer': 'rel=representation'
              }
            }
          );
          if (!res.ok) {
            tbody.innerHTML = `<tr><td colspan="7" class="empty-state"><h3>Erreur: ${res.status}</h3><p>Vérifiez les politiques RLS sur la table courses</p></td></tr>`;
            return;
          }
          const data = await res.json();
          renderTable(data, tbody);
        } catch (err) {
          console.error('[refresh] error:', err);
          tbody.innerHTML = `<tr><td colspan="7" class="empty-state"><h3>Erreur réseau</h3></td></tr>`;
        }
      }

      // --- Auth gate + load courses ---
      (async () => {
        const content = document.getElementById('admin-content');
        if (!content) return;

        const token = getToken();
        if (!token) {
          logout();
          return;
        }

        const userEmail = getUserEmail();
        if (!userEmail) {
          logout();
          return;
        }

        try {
          const profileRes = await fetch(
            `${SUPABASE_URL}/rest/v1/profiles?select=role&email=eq.${encodeURIComponent(userEmail)}`,
            {
              headers: {
                'apikey': SUPABASE_KEY,
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
              }
            }
          );

          if (!profileRes.ok) {
            logout();
            return;
          }

          const profileData = await profileRes.json();

          if (profileData.length === 0 || profileData[0].role !== 'admin') {
            logout();
            return;
          }

          // Auth verified — show content and load courses from Supabase
          content.style.display = 'block';
          await refreshCourses();
        } catch (err) {
          console.error('[auth] error:', err);
          logout();
        }
      })();

      // --- Delete course ---
      async function confirmDelete(btn) {
        const slug = btn.dataset.slug;
        const title = btn.dataset.title;
        if (!confirm(`"${title}"\n\nConfirmer la suppression ?\n\nCe cours sera supprimé de la base de données ET du catalogue.`)) return;

        btn.disabled = true;
        btn.textContent = 'Suppression...';

        const token = getToken();
        if (!token) {
          alert('Erreur: non connecté. Veuillez vous reconnecter.');
          btn.disabled = false;
          btn.textContent = 'Supprimer';
          return;
        }

        try {
          // Call Astro API route (handles Supabase + catalog cleanup server-side)
          const res = await fetch(`/Level-Up-Formation/api/admin/courses/${slug}`, {
            method: 'DELETE',
            headers: {
              'Authorization': `Bearer ${token}`,
              'Content-Type': 'application/json'
            }
          });

          const result = await res.json();

          if (!res.ok) {
            alert(`Erreur (${res.status}): ${result.error || 'Erreur inconnue'}`);
            btn.disabled = false;
            btn.textContent = 'Supprimer';
            return;
          }

          // Remove from DOM
          const row = btn.closest('tr');
          if (row) row.remove();

          alert(`✅ Cours "${title}" supprimé !`);
        } catch (e) {
          console.error('[delete] error:', e);
          alert('Erreur: ' + e.message);
        }
        btn.disabled = false;
        btn.textContent = 'Supprimer';
      }
    </script>
  </body>
</html>
