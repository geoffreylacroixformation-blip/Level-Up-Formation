---
import Layout from '../layouts/Layout.astro';
import { useTranslations, getLocalizedPath, defaultLang } from '../lib/i18n';

const lang = defaultLang;
const t = useTranslations(lang);
---

<Layout title={t.member.title}>
  <div class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="auth-section" class="mb-12">
        <div id="login-form" class="max-w-md mx-auto bg-surface rounded-xl p-8">
          <div class="text-center mb-6">
            <h1 class="font-display text-2xl font-bold mb-2">{t.auth.login}</h1>
          </div>

          <div class="flex gap-2 mb-6">
            <button id="tab-login" class="flex-1 py-2 bg-primary text-white rounded-lg font-medium">
              {t.auth.login}
            </button>
            <button id="tab-register" class="flex-1 py-2 bg-surface-light text-text-muted rounded-lg font-medium">
              {t.auth.register}
            </button>
          </div>

          <form id="auth-form" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium mb-1">{t.auth.email}</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 bg-surface-light border border-border rounded-lg focus:border-primary focus:outline-none"
                placeholder="votre@email.com"
              />
            </div>
            <div>
              <label for="password" class="block text-sm font-medium mb-1">{t.auth.password}</label>
              <input
                type="password"
                id="password"
                name="password"
                required
                class="w-full px-4 py-2 bg-surface-light border border-border rounded-lg focus:border-primary focus:outline-none"
              />
            </div>
            <div id="confirm-password-field" class="hidden">
              <label for="confirm-password" class="block text-sm font-medium mb-1">{t.auth.confirmPassword}</label>
              <input
                type="password"
                id="confirm-password"
                name="confirm-password"
                class="w-full px-4 py-2 bg-surface-light border border-border rounded-lg focus:border-primary focus:outline-none"
              />
            </div>
            <button
              type="submit"
              class="w-full py-3 bg-primary text-white rounded-lg font-semibold transition-colors"
            >
              {t.auth.loginSubmit}
            </button>
          </form>

          <div class="mt-4 text-center">
            <button id="magic-link-btn" class="text-sm text-accent">
              {t.auth.magicLink}
            </button>
          </div>

          <div id="auth-error" class="mt-4 p-3 text-error text-sm hidden"></div>
        </div>
      </div>

      <div id="dashboard" class="hidden">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h1 class="font-display text-2xl font-bold">{t.member.welcome} <span id="user-name"></span></h1>
            <p class="text-text-muted">Tableau de bord</p>
          </div>
          <button id="logout-btn" class="px-4 py-2 bg-surface-light text-text-muted rounded-lg transition-colors">
            {t.nav.logout}
          </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <div class="bg-surface rounded-xl p-6">
            <p class="text-2xl font-bold" id="courses-count">0</p>
            <p class="text-text-muted text-sm">{t.member.myCourses}</p>
          </div>

          <div class="bg-surface rounded-xl p-6">
            <p class="text-2xl font-bold" id="progress-percent">0%</p>
            <p class="text-text-muted text-sm">{t.member.progress}</p>
          </div>

          <div class="bg-surface rounded-xl p-6">
            <p class="text-2xl font-bold" id="badges-count">0</p>
            <p class="text-text-muted text-sm">{t.member.badges}</p>
          </div>
        </div>

        <section class="mb-12">
          <h2 class="font-display text-xl font-semibold mb-6">{t.member.myCourses}</h2>
          <div id="my-courses" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="bg-surface rounded-xl p-6 text-center">
              <p class="text-text-muted mb-4">{t.member.noCourses}</p>
              <a href={getLocalizedPath('catalogue', lang)} class="text-primary">{t.member.browse}</a>
            </div>
          </div>
        </section>

        <section>
          <h2 class="font-display text-xl font-semibold mb-6">{t.member.certificates}</h2>
          <div id="my-certificates" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-surface rounded-xl p-6 text-center">
              <p class="text-text-muted">Terminez une formation pour obtenir votre premier certificat</p>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{}}>
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';

  if (supabaseUrl && supabaseAnonKey) {
    const supabase = createClient(supabaseUrl, supabaseAnonKey);

    const loginForm = document.getElementById('login-form');
    const dashboard = document.getElementById('dashboard');
    const tabLogin = document.getElementById('tab-login');
    const tabRegister = document.getElementById('tab-register');
    const confirmPasswordField = document.getElementById('confirm-password-field');
    const authError = document.getElementById('auth-error');
    const authForm = document.getElementById('auth-form') as HTMLFormElement | null;

    let isLoginMode = true;

    tabLogin?.addEventListener('click', () => {
      isLoginMode = true;
      tabLogin.classList.add('bg-primary', 'text-white');
      tabLogin.classList.remove('bg-surface-light', 'text-text-muted');
      tabRegister?.classList.remove('bg-primary', 'text-white');
      tabRegister?.classList.add('bg-surface-light', 'text-text-muted');
      confirmPasswordField?.classList.add('hidden');
      authError?.classList.add('hidden');
    });

    tabRegister?.addEventListener('click', () => {
      isLoginMode = false;
      tabRegister.classList.add('bg-primary', 'text-white');
      tabRegister.classList.remove('bg-surface-light', 'text-text-muted');
      tabLogin?.classList.remove('bg-primary', 'text-white');
      tabLogin?.classList.add('bg-surface-light', 'text-text-muted');
      confirmPasswordField?.classList.remove('hidden');
      authError?.classList.add('hidden');
    });

    authForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const passwordInput = document.getElementById('password') as HTMLInputElement;

      if (emailInput && passwordInput) {
        const email = emailInput.value;
        const password = passwordInput.value;

        if (isLoginMode) {
          const { error } = await supabase.auth.signInWithPassword({ email, password });
          if (error && authError) {
            authError.textContent = error.message;
            authError.classList.remove('hidden');
          }
        } else {
          const confirmInput = document.getElementById('confirm-password') as HTMLInputElement;
          if (confirmInput && password !== confirmInput.value) {
            if (authError) {
              authError.textContent = 'Les mots de passe ne correspondent pas';
              authError.classList.remove('hidden');
            }
            return;
          }
          const { error } = await supabase.auth.signUp({ email, password });
          if (error && authError) {
            authError.textContent = error.message;
            authError.classList.remove('hidden');
          }
        }
      }
    });

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
    });

    supabase.auth.onAuthStateChange((_, session) => {
      if (session) {
        loginForm?.classList.add('hidden');
        dashboard?.classList.remove('hidden');
        const userName = document.getElementById('user-name');
        if (userName) userName.textContent = session.user.email?.split('@')[0] || 'Utilisateur';
      } else {
        loginForm?.classList.remove('hidden');
        dashboard?.classList.add('hidden');
      }
    });

    supabase.auth.getSession().then(({ data: { session } }) => {
      if (session) {
        loginForm?.classList.add('hidden');
        dashboard?.classList.remove('hidden');
        const userName = document.getElementById('user-name');
        if (userName) userName.textContent = session.user.email?.split('@')[0] || 'Utilisateur';
      }
    });
  }
</script>
