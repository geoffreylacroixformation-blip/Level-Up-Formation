---
import Layout from '../layouts/Layout.astro';
import { useTranslations, getLocalizedPath, defaultLang } from '../lib/i18n';

const lang = defaultLang;
const t = useTranslations(lang);
---

<Layout title={t.home.hero.title}>
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/20 via-background to-accent/10"></div>
    <div class="absolute inset-0">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/30 rounded-full blur-3xl animate-pulse-glow"></div>
      <div class="absolute bottom-1/4 right-1/4 w-72 h-72 bg-accent/20 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 1s"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex justify-center mb-8">
        <img src={`${import.meta.env.BASE_URL}/logo.jpg`} alt="Level Up - École Cyber Virtuelle" class="h-40 sm:h-52 w-auto drop-shadow-2xl" />
      </div>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-primary via-accent to-primary bg-clip-text text-transparent">
        {t.home.hero.title}
      </h1>
      <p class="text-text-muted text-lg sm:text-xl mb-8 max-w-2xl mx-auto">
        {t.home.hero.subtitle}
      </p>
      <a
        href={getLocalizedPath('catalogue', lang)}
        class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white font-semibold rounded-lg transition-all glow-primary"
      >
        {t.home.hero.cta}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-center mb-12">{t.home.why.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="gradient-border rounded-xl p-6 text-center transition-all">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary/20 rounded-lg flex items-center justify-center">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-2">{t.home.why.reason1.title}</h3>
          <p class="text-text-muted text-sm">{t.home.why.reason1.desc}</p>
        </div>

        <div class="gradient-border rounded-xl p-6 text-center transition-all">
          <div class="w-16 h-16 mx-auto mb-4 bg-accent/20 rounded-lg flex items-center justify-center">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-2">{t.home.why.reason2.title}</h3>
          <p class="text-text-muted text-sm">{t.home.why.reason2.desc}</p>
        </div>

        <div class="gradient-border rounded-xl p-6 text-center transition-all">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary/20 rounded-lg flex items-center justify-center">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-lg mb-2">{t.home.why.reason3.title}</h3>
          <p class="text-text-muted text-sm">{t.home.why.reason3.desc}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-center mb-12">{t.home.levels.title}</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="gradient-border rounded-xl p-6 transition-all">
          <div class="flex items-center justify-between mb-4">
            <span class="bg-success text-black text-xs font-bold px-2 py-1 rounded">LVL1</span>
            <span class="text-2xl font-bold text-primary">49€</span>
          </div>
          <h3 class="font-display font-semibold text-lg mb-2">{t.home.levels.lvl1.name}</h3>
          <p class="text-text-muted text-sm">{t.home.levels.lvl1.desc}</p>
        </div>

        <div class="gradient-border rounded-xl p-6 transition-all">
          <div class="flex items-center justify-between mb-4">
            <span class="bg-warning text-black text-xs font-bold px-2 py-1 rounded">LVL2</span>
            <span class="text-2xl font-bold text-accent">89€</span>
          </div>
          <h3 class="font-display font-semibold text-lg mb-2">{t.home.levels.lvl2.name}</h3>
          <p class="text-text-muted text-sm">{t.home.levels.lvl2.desc}</p>
        </div>

        <div class="gradient-border rounded-xl p-6 transition-all">
          <div class="flex items-center justify-between mb-4">
            <span class="bg-error text-white text-xs font-bold px-2 py-1 rounded">LVL3</span>
            <span class="text-2xl font-bold text-error">149€</span>
          </div>
          <h3 class="font-display font-semibold text-lg mb-2">{t.home.levels.lvl3.name}</h3>
          <p class="text-text-muted text-sm">{t.home.levels.lvl3.desc}</p>
        </div>
      </div>

      <div class="bg-surface rounded-xl p-8">
        <h3 class="font-display text-xl font-semibold mb-6 text-center">{t.home.levels.bundles.title}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-surface-light rounded-lg p-4 flex items-center justify-between transition-colors cursor-pointer">
            <div>
              <p class="font-semibold">{t.home.levels.bundles.bundle1}</p>
              <p class="text-text-muted text-sm">2 formations</p>
            </div>
            <span class="text-xl font-bold text-success">119€</span>
          </div>
          <div class="bg-surface-light rounded-lg p-4 flex items-center justify-between transition-colors cursor-pointer bg-gradient-to-r from-primary/20 to-accent/20">
            <div>
              <p class="font-semibold">{t.home.levels.bundles.bundle2}</p>
              <p class="text-text-muted text-sm">Tout inclus</p>
            </div>
            <span class="text-xl font-bold text-primary">249€</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold text-center mb-12">{t.home.testimonials.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
