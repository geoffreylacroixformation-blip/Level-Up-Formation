---
import Layout from '../layouts/Layout.astro';
import { useTranslations, defaultLang } from '../lib/i18n';

const lang = defaultLang;
const t = useTranslations(lang);
---

<Layout title={t.unsubscribe.title}>
  <section class="py-12">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-3xl font-bold mb-8">{t.unsubscribe.title}</h1>

      <div class="bg-surface rounded-xl p-8">
        <p class="text-text-muted text-lg mb-6">
          {t.unsubscribe.message}
        </p>

        <form id="unsubscribe-form" class="space-y-6">
          <div>
            <label for="email" class="block text-sm font-medium mb-2">{t.unsubscribe.emailLabel}</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-surface-light border border-border rounded-lg focus:border-primary focus:outline-none transition-colors"
              placeholder="votre@email.com"
            />
          </div>

          <button
            type="submit"
            class="w-full bg-primary text-white font-semibold py-3 px-6 rounded-lg hover:bg-primary/90 transition-colors"
          >
            {t.unsubscribe.submit}
          </button>
        </form>

        <p class="text-text-muted text-sm mt-6">
          {t.unsubscribe.note}
        </p>
      </div>
    </div>
  </section>
</Layout>
