---
import Layout from '../layouts/Layout.astro';
import { useTranslations, getLocalizedPath, defaultLang } from '../lib/i18n';
import { courses, bundles, getCoursesByCategory } from '../lib/courses';

const lang = defaultLang;
const t = useTranslations(lang);

const levelColors: Record<number, string> = {
  1: 'bg-success text-black',
  2: 'bg-warning text-black',
  3: 'bg-error text-white',
};

const cybersecCourses = getCoursesByCategory('cybersecurite');
const cybersecLvl1 = cybersecCourses.filter(c => c.level === 1);
const cybersecLvl2 = cybersecCourses.filter(c => c.level === 2);
const cybersecLvl3 = cybersecCourses.filter(c => c.level === 3);
---

<Layout title={t.catalogue.title}>
  <section class="py-12 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-3xl font-bold mb-8">{t.catalogue.title}</h1>

      <div class="flex flex-wrap gap-2 mb-8">
        <button class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium">
          {t.catalogue.filter.all}
        </button>
        <button class="px-4 py-2 bg-success text-black rounded-lg text-sm font-medium">
          {t.catalogue.filter.lvl1}
        </button>
        <button class="px-4 py-2 bg-warning text-black rounded-lg text-sm font-medium">
          {t.catalogue.filter.lvl2}
        </button>
        <button class="px-4 py-2 bg-error text-white rounded-lg text-sm font-medium">
          {t.catalogue.filter.lvl3}
        </button>
      </div>

      <!-- ===== FORMATIONS CYBERSÉCURITÉ ===== -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-3 h-3 rounded-full bg-error"></div>
          <h2 class="font-display text-2xl font-bold">Cybersécurité</h2>
        </div>
        <p class="text-text-muted mb-8">13 formations pour couvrir l'ensemble du spectre de la sécurité informatique</p>

        <!-- LVL 1 -->
        {cybersecLvl1.length > 0 && (
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
              <span class="text-xs font-bold px-2 py-1 rounded bg-success text-black">LVL1</span>
              Fondations
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {cybersecLvl1.map((course) => (
                <a
                  href={getLocalizedPath(`cours/${course.slug}`, lang)}
                  class="gradient-border rounded-xl overflow-hidden transition-all group"
                >
                  <div class="aspect-video bg-surface-light relative">
                    <img src={course.image} alt={course.title} class="w-full h-full object-cover opacity-60" />
                    <span class={`absolute top-3 left-3 text-xs font-bold px-2 py-1 rounded ${levelColors[course.level]}`}>
                      LVL{course.level}
                    </span>
                  </div>
                  <div class="p-4">
                    <h3 class="font-semibold mb-2 transition-colors">{course.title}</h3>
                    <p class="text-text-muted text-sm mb-4">{course.description}</p>
                    <div class="flex items-center gap-3 text-xs text-text-muted mb-2">
                      <span>⏱ {course.duree_heures}h</span>
                      <span>� {course.modules.length} modules</span>
                    </div>
                    <div class="flex items-center justify-between mt-3 pt-3 border-t border-border">
                      <span class="text-xl font-bold text-primary">{course.price}€</span>
                      <span class="text-xs text-success font-medium">Découvrir →</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- LVL 2 -->
        {cybersecLvl2.length > 0 && (
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
              <span class="text-xs font-bold px-2 py-1 rounded bg-warning text-black">LVL2</span>
              Intermédiaire
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {cybersecLvl2.map((course) => (
                <a
                  href={getLocalizedPath(`cours/${course.slug}`, lang)}
                  class="gradient-border rounded-xl overflow-hidden transition-all group"
                >
                  <div class="aspect-video bg-surface-light relative">
                    <img src={course.image} alt={course.title} class="w-full h-full object-cover opacity-60" />
                    <span class={`absolute top-3 left-3 text-xs font-bold px-2 py-1 rounded ${levelColors[course.level]}`}>
                      LVL{course.level}
                    </span>
                  </div>
                  <div class="p-4">
                    <h3 class="font-semibold mb-2 transition-colors">{course.title}</h3>
                    <p class="text-text-muted text-sm mb-4">{course.description}</p>
                    <div class="flex items-center gap-3 text-xs text-text-muted mb-2">
                      <span>� {course.duree_heures}h</span>
                      <span>📚 {course.modules.length} modules</span>
                    </div>
                    <div class="flex items-center justify-between mt-3 pt-3 border-t border-border">
                      <span class="text-xl font-bold text-primary">{course.price}€</span>
                      <span class="text-xs text-success font-medium">Découvrir →</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- LVL 3 -->
        {cybersecLvl3.length > 0 && (
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
              <span class="text-xs font-bold px-2 py-1 rounded bg-error text-white">LVL3</span>
              Avancé
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {cybersecLvl3.map((course) => (
                <a
                  href={getLocalizedPath(`cours/${course.slug}`, lang)}
                  class="gradient-border rounded-xl overflow-hidden transition-all group"
                >
                  <div class="aspect-video bg-surface-light relative">
                    <img src={course.image} alt={course.title} class="w-full h-full object-cover opacity-60" />
                    <span class={`absolute top-3 left-3 text-xs font-bold px-2 py-1 rounded ${levelColors[course.level]}`}>
                      LVL{course.level}
                    </span>
                  </div>
                  <div class="p-4">
                    <h3 class="font-semibold mb-2 transition-colors">{course.title}</h3>
                    <p class="text-text-muted text-sm mb-4">{course.description}</p>
                    <div class="flex items-center gap-3 text-xs text-text-muted mb-2">
                      <span>⏱ {course.duree_heures}h</span>
                      <span>📚 {course.modules.length} modules</span>
                    </div>
                    <div class="flex items-center justify-between mt-3 pt-3 border-t border-border">
                      <span class="text-xl font-bold text-primary">{course.price}€</span>
                      <span class="text-xs text-success font-medium">Découvrir →</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- ===== BUNDLES ===== -->
      <div class="mb-16">
        <h2 class="font-display text-2xl font-bold mb-2 text-center">Nos Packs & Bundles</h2>
        <p class="text-text-muted text-center mb-8">Économisez en choisissant une offre groupée</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Bundle: 3 Formations LVL1 = 109€ -->
          <div class="gradient-border rounded-xl overflow-hidden transition-all hover:scale-[1.02]">
            <div class="bg-background p-6">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <h3 class="font-display font-semibold text-lg">3 Formations LVL1</h3>
                  <p class="text-text-muted text-sm">Fondations</p>
                </div>
                <span class="text-2xl font-bold text-primary">109€</span>
              </div>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="text-xs font-bold px-2 py-1 rounded bg-success text-black">LVL1</span>
              </div>
              <button class="w-full py-2 bg-primary text-white rounded-lg font-medium transition-colors">
                Découvrir
              </button>
            </div>
          </div>
          <!-- Bundle: 3 Formations LVL2 = 199€ -->
          <div class="gradient-border rounded-xl overflow-hidden transition-all hover:scale-[1.02]">
            <div class="bg-background p-6">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <h3 class="font-display font-semibold text-lg">3 Formations LVL2</h3>
                  <p class="text-text-muted text-sm">Intermédiaire</p>
                </div>
                <span class="text-2xl font-bold text-primary">199€</span>
              </div>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="text-xs font-bold px-2 py-1 rounded bg-warning text-black">LVL2</span>
              </div>
              <button class="w-full py-2 bg-primary text-white rounded-lg font-medium transition-colors">
                Découvrir
              </button>
            </div>
          </div>
          <!-- Bundle: 3 Formations LVL3 = 399€ -->
          <div class="gradient-border rounded-xl overflow-hidden transition-all hover:scale-[1.02]">
            <div class="bg-background p-6">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <h3 class="font-display font-semibold text-lg">3 Formations LVL3</h3>
                  <p class="text-text-muted text-sm">Avancé</p>
                </div>
                <span class="text-2xl font-bold text-primary">399€</span>
              </div>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="text-xs font-bold px-2 py-1 rounded bg-error text-white">LVL3</span>
              </div>
              <button class="w-full py-2 bg-primary text-white rounded-lg font-medium transition-colors">
                Découvrir
              </button>
            </div>
          </div>
          <!-- Bundle: 1 Formation LVL1 + 1 Formation LVL2 = 119€ -->
          <div class="gradient-border rounded-xl overflow-hidden transition-all hover:scale-[1.02]">
            <div class="bg-background p-6">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <h3 class="font-display font-semibold text-lg">1 Formation LVL1 + 1 Formation LVL2</h3>
                  <p class="text-text-muted text-sm">Combo</p>
                </div>
                <span class="text-2xl font-bold text-primary">119€</span>
              </div>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="text-xs font-bold px-2 py-1 rounded bg-success text-black">LVL1</span>
                <span class="text-xs font-bold px-2 py-1 rounded bg-warning text-black">LVL2</span>
              </div>
              <button class="w-full py-2 bg-primary text-white rounded-lg font-medium transition-colors">
                Découvrir
              </button>
            </div>
          </div>
          <!-- Bundle: 1 Formation LVL2 + 1 Formation LVL3 = 209€ -->
          <div class="gradient-border rounded-xl overflow-hidden transition-all hover:scale-[1.02]">
            <div class="bg-background p-6">
              <div class="flex items-center justify-between mb-4">
                <div>
                  <h3 class="font-display font-semibold text-lg">1 Formation LVL2 + 1 Formation LVL3</h3>
                  <p class="text-text-muted text-sm">Combo</p>
                </div>
                <span class="text-2xl font-bold text-primary">209€</span>
              </div>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="text-xs font-bold px-2 py-1 rounded bg-warning text-black">LVL2</span>
                <span class="text-xs font-bold px-2 py-1 rounded bg-error text-white">LVL3</span>
              </div>
              <button class="w-full py-2 bg-primary text-white rounded-lg font-medium transition-colors">
                Découvrir
              </button>
            </div>
          </div>
        </div>
      </div>

