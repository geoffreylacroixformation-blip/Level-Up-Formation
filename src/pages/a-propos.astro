---
import Layout from '../layouts/Layout.astro';
import { useTranslations, defaultLang } from '../lib/i18n';

const lang = defaultLang;
const t = useTranslations(lang);
---

<Layout title={t.about.title}>
  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-3xl font-bold mb-8">{t.about.title}</h1>

      <div class="prose prose-invert max-w-none mb-12">
        <p class="text-text-muted text-lg leading-relaxed">
          {t.about.story}
        </p>
      </div>

      <section class="mb-12">
        <h2 class="font-display text-2xl font-bold mb-8">{t.about.values.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="gradient-border rounded-xl p-6">
            <div class="w-12 h-12 bg-primary/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">{t.about.values.excellence}</h3>
            <p class="text-text-muted text-sm">{t.about.values.excellenceDesc}</p>
          </div>

          <div class="gradient-border rounded-xl p-6">
            <div class="w-12 h-12 bg-accent/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">{t.about.values.accessibility}</h3>
            <p class="text-text-muted text-sm">{t.about.values.accessibilityDesc}</p>
          </div>

          <div class="gradient-border rounded-xl p-6">
            <div class="w-12 h-12 bg-warning/20 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">{t.about.values.community}</h3>
            <p class="text-text-muted text-sm">{t.about.values.communityDesc}</p>
          </div>
        </div>
      </section>

      <section class="bg-surface rounded-xl p-8">
        <h2 class="font-display text-2xl font-bold mb-8 text-center">{t.about.stats.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div>
            <p class="text-4xl font-bold text-primary mb-2">2 500+</p>
            <p class="text-text-muted">{t.about.stats.students}</p>
          </div>
          <div>
            <p class="text-4xl font-bold text-accent mb-2">6</p>
            <p class="text-text-muted">{t.about.stats.courses}</p>
          </div>
          <div>
            <p class="text-4xl font-bold text-success mb-2">1 800+</p>
            <p class="text-text-muted">{t.about.stats.certificates}</p>
          </div>
        </div>
      </section>
    </div>
  </section>
</Layout>
